# Server
PORT=3001
NODE_ENV=development

# Database
DB_PATH=./data/vaultlegacy.db

# OP_NET
OPNET_NETWORK=testnet
OPNET_RPC_URL=https://testnet.opnet.org

# Email (Nodemailer — use Gmail App Password or SMTP service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=VaultLegacy <noreply@vaultlegacy.io>

# SMS (Twilio — optional, leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@gmail.com

# Uploads
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Frontend URL (for signing links sent to remote beneficiaries)
FRONTEND_URL=http://localhost:5173

# Security
JWT_SECRET=change-this-to-a-random-secret-in-production
